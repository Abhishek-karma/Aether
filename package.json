{
  "name": "aether",
  "displayName": "Aether",
  "description": "AI coding assistant powered by Google Gemini and local Ollama models",
  "version": "0.2.0",
  "publisher": "AetherTeam",
  "repository": {
    "type": "git",
    "url": "https://github.com/AetherTeam/aether.git"
  },
  "icon": "media/icon.svg",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aether.startChat",
        "title": "Aether: Start Chat"
      },
      {
        "command": "aether.newTask",
        "title": "Aether: New Task"
      },
      {
        "command": "aether.inlineChat",
        "title": "Aether: Inline Chat"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aether-sidebar",
          "title": "Aether",
          "icon": "media/icon.svg"
        }
      ]
    },
    "keybindings": [
      {
        "command": "aether.startChat",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "aether.inlineChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "views": {
      "aether-sidebar": [
        {
          "type": "webview",
          "id": "aetherChatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "Aether",
      "properties": {
        "aether.geminiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Your **Google Gemini API key**. Get one free at [aistudio.google.com](https://aistudio.google.com/apikey). Stored in VS Code settings; consider using a [Settings Sync secret](https://code.visualstudio.com/docs/editor/settings-sync) for security."
        },
        "aether.geminiModel": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "enum": [
            "gemini-2.5-flash",
            "gemini-2.5-pro",
            "gemini-2.0-flash",
            "gemini-2.0-flash-lite",
            "gemini-1.5-pro",
            "gemini-1.5-flash"
          ],
          "enumDescriptions": [
            "Gemini 2.5 Flash — fast thinking model with reasoning",
            "Gemini 2.5 Pro — most capable thinking model",
            "Gemini 2.0 Flash — balanced speed and quality",
            "Gemini 2.0 Flash Lite — lightweight and fast",
            "Gemini 1.5 Pro — large context window (1M tokens)",
            "Gemini 1.5 Flash — fast with large context"
          ],
          "description": "Default Gemini model shown in the chat toolbar."
        },
        "aether.ollamaBaseUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL for the local Ollama server used to discover and run local models."
        },
        "aether.defaultModel": {
          "type": "string",
          "default": "",
          "description": "Optional default local Ollama model name, such as llama3.2 or codellama:latest. Leave blank to use the first discovered local model when no NVIDIA API key is configured."
        },
        "aether.contextWindow": {
          "type": "number",
          "default": 8192,
          "minimum": 1024,
          "description": "Context window passed to local Ollama chat requests."
        },
        "aether.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature for chat responses."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "package": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "npm run test-compile",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "test-compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "esbuild": "^0.19.10",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.2.2",
    "@google/genai": "^0.14.0"
  }
}
